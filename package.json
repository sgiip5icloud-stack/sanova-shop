{
  "name": "sanova-shop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npx vite --port 5173",
    "build": "cd client && npx vite build && cd ..",
    "start": "cd client && npm run build && cd .. && NODE_ENV=production node --loader tsx server/index.ts",
    "db:push": "npx drizzle-kit push",
    "db:seed": "tsx server/seed.ts",
    "setup": "npm install && cd client && npm install && cd .. && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
